# OpenClaw Environment Variables — copy to .env and fill in values

PORT=3000

# ── AI Provider ───────────────────────────────────────────
# Anthropic Claude (paid per API call)
# ANTHROPIC_API_KEY=sk-ant-

# OpenAI (paid per API call)
# OPENAI_API_KEY=sk-

# Ollama — local LLM, completely free
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── App Settings ──────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
